modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "atk", "cairo", "chromium", "cups", "dbus", "expat", "gdk-pixbuf", "gitFull", "glib", "gtk3", "nspr", "nss", "pango", "playwright-driver", "xorg.libX11", "xorg.libXScrnSaver", "xorg.libXcomposite", "xorg.libXcursor", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXi", "xorg.libXrandr", "xorg.libXrender", "xorg.libXtst", "xorg.libxcb"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Keep-Alive Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Status Page"

[[workflows.workflow]]
name = "Keep-Alive Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python keep_alive.py"

[[workflows.workflow]]
name = "Status Page"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python web.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
