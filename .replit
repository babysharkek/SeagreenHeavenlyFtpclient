modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["gitFull", "playwright-driver", "chromium", "nss", "nspr", "atk", "cups", "xorg.libX11", "xorg.libxcb", "xorg.libXcomposite", "xorg.libXcursor", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXi", "xorg.libXrandr", "xorg.libXrender", "xorg.libXtst", "xorg.libXScrnSaver", "gtk3", "pango", "cairo", "gdk-pixbuf", "glib", "dbus", "expat", "alsa-lib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Keep-Alive Bot"

[[workflows.workflow]]
name = "Keep-Alive Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python keep_alive.py"

[workflows.workflow.metadata]
outputType = "console"
